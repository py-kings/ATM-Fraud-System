# Copy this file to .env and fill in your local MySQL credentials.
# app.py loads these via python-dotenv -- never hard-code credentials in code.

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=atm_fraud_system

FLASK_SECRET_KEY=change-this-to-a-random-string
FLASK_DEBUG=True
